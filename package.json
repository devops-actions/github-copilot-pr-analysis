{
  "name": "@rajbos/github-copilot-pr-analysis",
  "version": "1.0.0",
  "description": "GitHub Action and CLI to analyze GitHub PRs for Copilot usage",
  "main": "src/index.js",
  "bin": {
    "copilot-pr-analysis": "src/cli.js"
  },
  "type": "module",
  "files": [
    "src/",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devops-actions/github-copilot-pr-analysis.git"
  },
  "scripts": {
    "start": "node src/index.js",
    "analyze": "node src/index.js --mode=analyze",
    "charts": "node src/index.js --mode=charts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/"
  },
  "keywords": [
    "github",
    "pull-request",
    "analysis",
    "copilot",
    "automation",
    "github-actions",
    "cli"
  ],
  "author": "devops-actions",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.16.0",
    "node-cache": "^5.1.2",
    "commander": "^14.0.3",
    "csv-writer": "^1.6.0",
    "glob": "^13.0.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "eslint": "^10.3.0",
    "@babel/preset-env": "^7.29.5",
    "babel-jest": "^30.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}